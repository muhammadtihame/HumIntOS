HUMINTOS_ENV=development
HUMINTOS_TICK_SECONDS=1.0
HUMINTOS_REASONING_SECONDS=2.5

# Optional hosted assistant:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional local assistant fallback:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Hume AI realtime emotion intelligence:
HUME_API_KEY=
HUME_CONFIG_ID=
HUME_EVI_WS_URL=wss://api.hume.ai/v0/evi/chat
HUME_EVI_VERBOSE_TRANSCRIPTION=true
HUME_TTS_WS_URL=wss://api.hume.ai/v0/tts/stream/input
HUME_TTS_VOICE_NAME=Ava Song
HUME_TTS_VOICE_PROVIDER=HUME_AI
HUME_TEXT_TIMEOUT_SECONDS=8.0
